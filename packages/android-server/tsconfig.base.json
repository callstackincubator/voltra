{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "rootDir": "./src",
    "baseUrl": "../..",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "paths": {
      "voltra": ["packages/voltra/src/index.ts"],
      "voltra/*": ["packages/voltra/src/*"],
      "@voltra/android": ["packages/android/src/index.ts"],
      "@voltra/android/client": ["packages/android/src/client.ts"],
      "@voltra/android/server": ["packages/android/src/server.ts"],
      "@voltra/android-server": ["packages/android-server/src/index.ts"],
      "@voltra/core": ["packages/core/src/index.ts"],
      "@voltra/ios": ["packages/ios/src/index.ts"],
      "@voltra/ios/client": ["packages/ios/src/client.ts"],
      "@voltra/ios/server": ["packages/ios/src/server.ts"],
      "@voltra/ios-server": ["packages/ios-server/src/index.ts"],
      "@voltra/server": ["packages/server/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["./src"],
  "exclude": ["**/__mocks__/*", "**/__tests__/*", "**/__rsc_tests__/*"]
}
