{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "rootDir": "./src",
    "baseUrl": ".",
    "moduleResolution": "node",
    "paths": {
      "@use-voltra/android": ["../android/build/typescript/commonjs/index.d.ts"],
      "@use-voltra/android/server": ["../android/build/typescript/commonjs/server.d.ts"],
      "@use-voltra/android/internal": ["../android/build/typescript/commonjs/internal.d.ts"]
    },
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["./src"],
  "exclude": ["**/__mocks__/*", "**/__tests__/*", "**/__rsc_tests__/*"]
}
