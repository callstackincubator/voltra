{
  "name": "voltra",
  "version": "1.4.1",
  "description": "Build Live Activities with JSX in React Native",
  "main": "build/commonjs/index.js",
  "module": "build/module/index.js",
  "types": "build/typescript/commonjs/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./build/typescript/module/index.d.ts",
        "default": "./build/module/index.js"
      },
      "require": {
        "types": "./build/typescript/commonjs/index.d.ts",
        "default": "./build/commonjs/index.js"
      },
      "default": "./build/module/index.js"
    },
    "./client": {
      "source": "./src/client.ts",
      "import": {
        "types": "./build/typescript/module/client.d.ts",
        "default": "./build/module/client.js"
      },
      "require": {
        "types": "./build/typescript/commonjs/client.d.ts",
        "default": "./build/commonjs/client.js"
      },
      "default": "./build/module/client.js"
    },
    "./server": {
      "source": "./src/ios/server.ts",
      "import": {
        "types": "./build/typescript/module/ios/server.d.ts",
        "default": "./build/module/ios/server.js"
      },
      "require": {
        "types": "./build/typescript/commonjs/ios/server.d.ts",
        "default": "./build/commonjs/ios/server.js"
      },
      "default": "./build/module/ios/server.js"
    },
    "./android": {
      "source": "./src/android/index.ts",
      "import": {
        "types": "./build/typescript/module/android/index.d.ts",
        "default": "./build/module/android/index.js"
      },
      "require": {
        "types": "./build/typescript/commonjs/android/index.d.ts",
        "default": "./build/commonjs/android/index.js"
      },
      "default": "./build/module/android/index.js"
    },
    "./android/server": {
      "source": "./src/android/server.ts",
      "import": {
        "types": "./build/typescript/module/android/server.d.ts",
        "default": "./build/module/android/server.js"
      },
      "require": {
        "types": "./build/typescript/commonjs/android/server.d.ts",
        "default": "./build/commonjs/android/server.js"
      },
      "default": "./build/module/android/server.js"
    },
    "./android/client": {
      "source": "./src/android/client.ts",
      "import": {
        "types": "./build/typescript/module/android/client.d.ts",
        "default": "./build/module/android/client.js"
      },
      "require": {
        "types": "./build/typescript/commonjs/android/client.d.ts",
        "default": "./build/commonjs/android/client.js"
      },
      "default": "./build/module/android/client.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run clean && bob build",
    "clean": "rm -rf build",
    "format:check": "npm run format:js:check",
    "format:fix": "npm run format:js:fix && npm run lint:fix",
    "format:js:check": "prettier --check .",
    "format:js:fix": "prettier --write .",
    "generate": "ts-node generator/generate-types.ts",
    "lint": "oxlint src generator",
    "lint:fix": "oxlint --fix src generator",
    "test": "expo-module test",
    "test:js": "npm run test",
    "test:all": "npm run test:js && npm run test:native",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "keywords": [
    "react-native",
    "expo",
    "live-activity",
    "ios",
    "apple"
  ],
  "author": "Saúl Sharma (https://x.com/saul_sharma), Szymon Chmal (https://x.com/chmalszymon)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callstackincubator/voltra.git",
    "directory": "packages/voltra"
  },
  "bugs": {
    "url": "https://github.com/callstackincubator/voltra/issues"
  },
  "license": "MIT",
  "homepage": "https://use-voltra.dev",
  "dependencies": {
    "@use-voltra/android": "1.4.1",
    "@use-voltra/android-client": "1.4.1",
    "@use-voltra/android-server": "1.4.1",
    "@use-voltra/core": "1.4.1",
    "@use-voltra/ios": "1.4.1",
    "@use-voltra/ios-client": "1.4.1",
    "@use-voltra/ios-server": "1.4.1",
    "@use-voltra/server": "1.4.1",
    "react-is": "^19.2.0"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "build",
    "exclude": "**/{__tests__,__fixtures__,__mocks__,__rsc_tests__}/**",
    "targets": [
      [
        "module",
        {
          "esm": true,
          "sourceMaps": true
        }
      ],
      [
        "commonjs",
        {
          "esm": true,
          "sourceMaps": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "devDependencies": {
    "ts-node": "^10.9.0",
    "typescript": "~5.9.2"
  }
}
