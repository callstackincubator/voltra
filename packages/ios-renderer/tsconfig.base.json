{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "rootDir": "./src",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["./src"],
  "exclude": ["**/__tests__/*"]
}