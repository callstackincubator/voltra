{
  "name": "@voltra/core",
  "version": "1.3.0-rc.1",
  "description": "Shared renderer, types, and payload utilities for Voltra",
  "main": "build/cjs/index.js",
  "module": "build/esm/index.js",
  "types": "build/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/types/index.d.ts",
      "require": "./build/cjs/index.js",
      "import": "./build/esm/index.js",
      "default": "./build/esm/index.js"
    },
    "package.json": "./package.json"
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:esm && npm run build:cjs && npm run build:types",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rm -rf build"
  },
  "dependencies": {
    "react-is": "^19.2.0"
  },
  "keywords": [
    "react-native",
    "expo",
    "voltra",
    "renderer",
    "jsx"
  ],
  "author": "Saúl Sharma (https://x.com/saul_sharma), Szymon Chmal (https://x.com/chmalszymon)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/callstackincubator/voltra.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/callstackincubator/voltra/issues"
  },
  "license": "MIT",
  "homepage": "https://use-voltra.dev",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  }
}
