{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["ANDROID_HOME"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**"]
    },
    "test": {
      "dependsOn": ["^build", "build"],
      "cache": false
    },
    "test:kotlin": {
      "cache": false
    },
    "test:swift": {
      "cache": false
    },
    "lint": {},
    "lint:libOnly": {},
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "format:check": {},
    "generate": {
      "outputs": ["src/**/*.generated.ts"]
    },
    "clean": {
      "cache": false
    },
    "version-packages": {
      "cache": false
    }
  }
}
